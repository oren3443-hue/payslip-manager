      "id": "79cc9a90-3432-42e4-8c9a-aff6e51c5ca0",
      "name": "Send a message",
      "type": "n8n-nodes-base.microsoftOutlook",
      "typeVersion": 2,
      "position": [1872, -672],
      "onError": "continueRegularOutput"
    },
    {
      "parameters": {
        "jsCode": "const items = $input.all();\nconst failed = items.filter(i => i.json.error || i.error).map(i => ({\n  email: i.json.current_email || 'unknown',\n  error: String((i.json.error && i.json.error.message) || (i.error && i.error.message) || 'unknown error')\n}));\nconst sent = items.length - failed.length;\nreturn [{\n  json: {\n    status: failed.length === 0 ? 'sent' : (sent === 0 ? 'error' : 'partial'),\n    sent: sent,\n    failed: failed.length,\n    total: items.length,\n    failures: failed,\n    schedule_mode: (items[0] && items[0].json && items[0].json.schedule_mode) || 'now'\n  }\n}];"
      },
      "id": "01e999be-9e5d-45e3-911e-d64624a17a8c",
